{"id": "agent-001", "type": "multi_step_analysis", "scenario": "Analyze this cluster for security issues", "context": {"cluster_info": "3-node k8s cluster running nginx, redis, postgres", "available_tools": ["kubectl", "trivy", "kubescape", "gitleaks"], "environment": "production"}, "expected_steps": ["1. Run kubescape scan for misconfigs", "2. Run trivy for vulnerabilities", "3. Check RBAC with kubectl", "4. Review network policies", "5. Generate findings report"], "max_tool_calls": 10, "success_criteria": "identifies_at_least_3_issues"}
