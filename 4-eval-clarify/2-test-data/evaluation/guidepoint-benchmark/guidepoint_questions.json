      "id": "cicd-002",
      "domain": "CI/CD Security",
      "priority": "HIGH",
      "difficulty": "B-rank",
      "question": "Write a GitHub Actions workflow that runs Trivy on a Docker image, fails on HIGH/CRITICAL CVEs, and uploads results as SARIF to GitHub Security tab.",
      "expected_elements": ["aquasecurity/trivy-action", "severity filter", "sarif output", "github/codeql-action/upload-sarif"],
      "scoring_rubric": {
        "correct_trivy_action": 2,
        "severity_threshold": 2,
        "sarif_output": 3,
        "upload_to_security_tab": 3
      }
    },
    {
      "id": "aws-001",
      "domain": "Cloud Security",
      "priority": "HIGH",
      "difficulty": "C-rank",
      "question": "An EKS pod needs to access S3. Write the IAM policy and explain how to attach it using IRSA (IAM Roles for Service Accounts).",
      "expected_elements": ["IAM policy with S3 permissions", "ServiceAccount annotation", "eks.amazonaws.com/role-arn", "trust policy with OIDC"],
      "scoring_rubric": {
        "correct_iam_policy": 2,
        "explains_irsa_setup": 3,
        "correct_serviceaccount_annotation": 3,
        "mentions_trust_policy": 2
      }
    },
    {
      "id": "aws-002",
      "domain": "Cloud Security",
      "priority": "HIGH",
      "difficulty": "B-rank",
      "question": "Write a Prowler check command to audit AWS for CIS Benchmark compliance, output to HTML, and explain the top 5 most critical findings to look for.",
      "expected_elements": ["prowler command", "CIS compliance flag", "HTML output", "critical findings explanation"],
      "scoring_rubric": {
        "correct_prowler_syntax": 2,
        "cis_compliance_flag": 2,
        "output_format": 2,
        "critical_findings_explanation": 4
      }
    },
    {
      "id": "devsecops-001",
      "domain": "DevSecOps",
      "priority": "HIGH",
      "difficulty": "C-rank",
      "question": "Design a shift-left security pipeline with these stages: secrets scan, SAST, dependency scan, container scan. Which tools would you use for each and in what order?",
      "expected_elements": ["gitleaks/trufflehog for secrets", "semgrep/bandit for SAST", "trivy/grype for deps", "trivy/snyk for containers", "order matters"],
      "scoring_rubric": {
        "appropriate_tools": 3,
        "correct_order": 2,
        "explains_shift_left": 2,
        "fail_fast_strategy": 2,
        "mentions_speed_vs_thoroughness": 1
      }
    },
