      "expected_elements": ["CIS Kubernetes Benchmark IDs", "SOC2 criteria mapping", "specific control numbers"],
      "scoring_rubric": {
        "correct_cis_ids": 4,
        "soc2_mapping": 3,
        "explains_relationship": 3
      }
