{
  "benchmark_name": "GuidePoint Security Domain Benchmark",
  "version": "1.0",
  "description": "Tests specialized knowledge in GuidePoint Security consulting domains",
  "questions": [
    {
      "id": "k8s-001",
      "domain": "Container Security",
      "priority": "HIGH",
      "difficulty": "C-rank",
      "question": "A pod is failing with CrashLoopBackOff. The logs show 'OOMKilled'. The deployment has no resource limits set. Write the specific YAML patch to fix this for a Node.js application that typically uses 256Mi memory.",
      "expected_elements": ["resources.limits.memory", "resources.requests.memory", "256Mi or 512Mi", "proper YAML format"],
      "scoring_rubric": {
        "correct_yaml_syntax": 2,
        "includes_limits": 2,
        "includes_requests": 2,
        "reasonable_values": 2,
        "explains_why": 2
      }
    },
    {
      "id": "k8s-002",
      "domain": "Container Security",
      "priority": "HIGH",
      "difficulty": "C-rank",
      "question": "Write a Kyverno ClusterPolicy that denies pods running as root (runAsNonRoot must be true).",
      "expected_elements": ["apiVersion: kyverno.io/v1", "kind: ClusterPolicy", "validate", "runAsNonRoot", "deny or Enforce"],
      "scoring_rubric": {
        "correct_api_version": 2,
        "proper_policy_structure": 2,
        "correct_validation_rule": 3,
        "handles_containers_and_initContainers": 2,
        "clear_message": 1
      }
    },
    {
      "id": "k8s-003",
      "domain": "Container Security",
      "priority": "HIGH",
      "difficulty": "B-rank",
      "question": "Create a Pod Security Standard (PSS) restricted namespace configuration using labels. Show the namespace YAML and explain what gets blocked.",
      "expected_elements": ["pod-security.kubernetes.io/enforce: restricted", "namespace labels", "what restricted blocks"],
      "scoring_rubric": {
        "correct_labels": 3,
        "correct_namespace_yaml": 2,
        "explains_restricted_profile": 3,
        "mentions_audit_warn_modes": 2
      }
    },
    {
      "id": "opa-001",
      "domain": "CNAPP",
      "priority": "HIGH",
      "difficulty": "C-rank",
      "question": "Write an OPA Rego policy that denies deployments without the label 'app.kubernetes.io/managed-by'.",
      "expected_elements": ["package", "deny", "input.request.object", "metadata.labels", "app.kubernetes.io/managed-by"],
      "scoring_rubric": {
        "correct_package_declaration": 1,
        "proper_deny_rule": 3,
        "correct_label_check": 3,
        "descriptive_message": 2,
        "handles_missing_labels": 1
      }
    },
    {
      "id": "opa-002",
      "domain": "CNAPP",
      "priority": "HIGH",
      "difficulty": "B-rank",
      "question": "Write a Gatekeeper ConstraintTemplate that limits container images to only come from 'gcr.io/my-project/' or 'docker.io/library/'. Include the Constraint that uses it.",
      "expected_elements": ["ConstraintTemplate", "Constraint", "allowedRepos parameter", "startswith or regex"],
      "scoring_rubric": {
        "correct_constrainttemplate_structure": 3,
        "proper_rego_in_template": 3,
        "correct_constraint_that_uses_it": 2,
        "parameterized_repos": 2
      }
    },
    {
      "id": "iac-001",
      "domain": "IaC Security",
      "priority": "HIGH",
      "difficulty": "C-rank",
      "question": "This Terraform has a security issue. Identify and fix it:\n\nresource \"aws_security_group\" \"web\" {\n  ingress {\n    from_port   = 22\n    to_port     = 22\n    protocol    = \"tcp\"\n    cidr_blocks = [\"0.0.0.0/0\"]\n  }\n}",
      "expected_elements": ["SSH open to world", "restrict CIDR", "use specific IP or bastion"],
      "scoring_rubric": {
        "identifies_issue": 3,
        "provides_fix": 3,
        "explains_risk": 2,
        "suggests_bastion_or_vpn": 2
      }
    },
    {
      "id": "iac-002",
      "domain": "IaC Security",
      "priority": "HIGH",
      "difficulty": "B-rank",
      "question": "Write a Checkov custom check (in Python) that fails if an S3 bucket doesn't have versioning enabled.",
      "expected_elements": ["from checkov.terraform.checks.resource.base_resource_check", "CheckResult", "versioning", "get_inspected_key"],
      "scoring_rubric": {
        "correct_base_class": 2,
        "proper_check_structure": 3,
        "correct_resource_type": 2,
        "proper_scan_logic": 3
      }
    },
    {
      "id": "cicd-001",
      "domain": "CI/CD Security",
      "priority": "HIGH",
      "difficulty": "C-rank",
      "question": "This GitHub Actions workflow has a command injection vulnerability. Identify and fix it:\n\non: issue_comment\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - run: echo \"Processing: ${{ github.event.comment.body }}\"",
      "expected_elements": ["command injection", "untrusted input", "environment variable", "use env: block"],
      "scoring_rubric": {
        "identifies_injection": 3,
        "explains_attack_vector": 2,
        "provides_correct_fix": 3,
        "uses_env_block": 2
      }
    },
