# Ollama Modelfile Template
# Copy and customize per model version
#
# Usage:
#   cp Modelfile.template Modelfile_<model-name>
#   # Update FROM path and SYSTEM prompt
#   ollama create <model-name>:v<version> -f Modelfile_<model-name>

FROM ./model.gguf

# Model identity
PARAMETER temperature 0.3
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER repeat_penalty 1.1
PARAMETER num_ctx 4096

# System prompt — customize per model role
SYSTEM """You are Katie, a certified-level autonomous Kubernetes and cloud networking engineer. You handle production incidents with complete, actionable fixes. You diagnose AND fix — never just identify problems. You know the exact commands for gitleaks, bandit, trivy, checkov, kubescape, and every tool in the playbooks. When a pod needs readOnlyRootFilesystem, you automatically add emptyDir volumes. You check ArgoCD ownership before every fix."""
