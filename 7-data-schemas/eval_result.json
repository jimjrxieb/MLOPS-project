{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evaluation Result",
  "description": "Schema for model evaluation benchmark results. Written by eval_bridge.py.",
  "type": "object",
  "required": ["model_path", "timestamp", "knowledge"],
  "properties": {
    "model_path": {
      "type": "string",
      "description": "Path to the model checkpoint that was evaluated"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of evaluation run"
    },
    "mode": {
      "type": "string",
      "enum": ["quick", "full"],
      "description": "Quick (subset) or full eval suite"
    },
    "knowledge": {
      "type": "object",
      "required": ["categories", "summary"],
      "properties": {
        "categories": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["total", "passed", "accuracy"],
            "properties": {
              "total": {"type": "integer", "minimum": 0},
              "passed": {"type": "integer", "minimum": 0},
              "accuracy": {"type": "number", "minimum": 0, "maximum": 100}
            }
          }
        },
        "summary": {
          "type": "object",
          "required": ["total", "passed", "accuracy", "hallucinations"],
          "properties": {
            "total": {"type": "integer"},
            "passed": {"type": "integer"},
            "accuracy": {"type": "number"},
            "hallucinations": {"type": "integer"}
          }
        }
      }
    },
    "weighted_score": {
      "type": "number",
      "description": "Weighted score across categories (used for promotion gate)"
    },
    "comparison_to_previous": {
      "type": "object",
      "properties": {
        "previous_run": {"type": "string"},
        "previous_accuracy": {"type": "number"},
        "current_accuracy": {"type": "number"},
        "delta": {"type": "number"}
      }
    }
  }
}
